---
// @ts-check
import Layout from "../layouts/Layout.astro";
import FooterBar from "../components/FooterBar.astro";

const quickLinks = [
  { label: "Homepage", href: "/"         },
  { label: "Selected Work", href: "/work/"     },
  { label: "About Me", href: "/about/"    },
  { label: "Contact", href: "/contact/"  },
];
---

<Layout
  title="404 — Page Not Found | Mohammed Shammas"
  description="The requested page could not be found. Return to the homepage or explore selected work."
>
  <main class="pt-24 pb-[var(--spacing-section-padding)] flex flex-col justify-center min-h-[70vh]">
    <section class="px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto text-center scroll-reveal">

      <!-- Badge -->
      <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-tertiary-container bg-surface-container-high py-1.5 px-4 rounded-sm inline-block mb-6 uppercase">
        ERROR 404
      </span>

      <!-- 404 Display Number -->
      <h1 class="font-plus-jakarta-sans font-bold text-[80px] sm:text-[120px] md:text-[160px] leading-none text-primary tracking-tighter mb-4 select-none">
        404
      </h1>

      <!-- Main Headline -->
      <h2 class="font-plus-jakarta-sans font-semibold text-[28px] sm:text-[36px] md:text-[48px] text-primary mb-6 leading-tight">
        Page Not Found
      </h2>

      <!-- Description -->
      <p class="font-plus-jakarta-sans text-[16px] sm:text-[18px] text-on-surface-variant max-w-xl mx-auto mb-10 leading-relaxed">
        The page or resource you are seeking has been relocated, renamed, or does not exist within this architecture.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-wrap justify-center items-center gap-4 mb-16">
        <a
          href="/"
          class="bg-primary text-on-primary px-8 py-4 rounded-sm font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold uppercase hover:opacity-90 transition-opacity active:scale-95 inline-flex items-center gap-2"
        >
          <span class="material-symbols-outlined text-[20px]" aria-hidden="true">arrow_back</span>
          Return to Homepage
        </a>
        <a
          href="/work/"
          class="border border-primary text-primary px-8 py-4 rounded-sm font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold uppercase hover:bg-primary hover:text-white transition-all active:scale-95 inline-flex"
        >
          Explore Work
        </a>
      </div>

      <!-- Quick Navigation Grid -->
      <div class="border-t border-outline-variant pt-10 max-w-md mx-auto">
        <p class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-secondary uppercase mb-4">
          Quick Destination Links
        </p>
        <nav aria-label="404 quick links" class="flex flex-wrap justify-center gap-6">
          {quickLinks.map((link) => (
            <a
              href={link.href}
              class="font-plus-jakarta-sans text-[14px] text-primary font-medium hover:underline underline-offset-4 transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

    </section>
  </main>

  <FooterBar />
</Layout>
