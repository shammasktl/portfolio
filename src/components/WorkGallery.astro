---

<div class="pt-8 pb-[var(--spacing-section-padding)]">
  <!-- Header Section -->
  <header class="max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] mb-16 scroll-reveal">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-2xl">
        <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-on-primary bg-primary py-1 px-3 mb-6 inline-block rounded-sm uppercase">
          Curated Gallery
        </span>
        <h1 class="font-plus-jakarta-sans font-semibold text-primary text-[32px] md:text-[48px] leading-tight uppercase mb-4">
          Selected Work
        </h1>
        <p class="font-plus-jakarta-sans text-[18px] text-secondary leading-relaxed">
          A meticulous selection of strategic design interventions and high-performance development projects executed for global clients.
        </p>
      </div>

      <!-- Category Filter Tabs -->
      <nav aria-label="Project categories filter" class="flex items-center gap-6 overflow-x-auto pb-2 scrollbar-none">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat.key}
            class={[
              "filter-btn font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold uppercase whitespace-nowrap py-2 transition-all duration-200 cursor-pointer border-b-2",
              idx === 0
                ? "active text-primary border-primary"
                : "text-secondary border-transparent hover:text-primary",
            ].join(" ")}
          >
            {cat.label}
          </button>
        ))}
      </nav>
    </div>
  </header>

  <!-- Project Grid -->
  <section class="max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)]">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[var(--spacing-gutter)] scroll-stagger" id="project-grid">
      {projects.map((project) => (
        <article
          class={[
            "project-card group cursor-pointer scroll-stagger-item transition-all duration-300",
            project.isLarge ? "col-span-1 md:col-span-2" : "col-span-1",
          ].join(" ")}
          data-category={project.category}
        >
          <a href={project.href} class="block">
            <!-- Image Wrapper -->
            <div class={`relative ${project.aspectRatio} overflow-hidden bg-surface-container-high rounded-lg mb-6 border border-outline-variant`}>
              <img
                src={project.imageUrl}
                alt={project.imageAlt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="project-image-overlay absolute inset-0 bg-primary/10 opacity-0 transition-opacity duration-300"></div>
            </div>

            <!-- Card Info -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
              <div>
                <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-tertiary-container mb-2 block uppercase">
                  {project.subtitle}
                </span>
                <h3 class="font-plus-jakarta-sans font-semibold text-[24px] md:text-[32px] text-primary group-hover:text-tertiary transition-colors leading-tight">
                  {project.title}
                </h3>
              </div>
              <span class="material-symbols-outlined text-primary text-3xl transition-transform group-hover:translate-x-2" aria-hidden="true">
                arrow_right_alt
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</div>

<script>
  function initProjectFilters() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const projects = document.querySelectorAll<HTMLElement>('.project-card');

    if (!buttons.length || !projects.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-filter');

        // Update active button state
        buttons.forEach((b) => {
          b.classList.remove('active', 'text-primary', 'border-primary');
          b.classList.add('text-secondary', 'border-transparent');
        });
        btn.classList.add('active', 'text-primary', 'border-primary');
        btn.classList.remove('text-secondary', 'border-transparent');

        // Filter project items smoothly
        projects.forEach((project) => {
          const itemCategory = project.getAttribute('data-category');
          if (category === 'all' || itemCategory === category) {
            project.style.display = 'block';
            requestAnimationFrame(() => {
              project.style.opacity = '1';
              project.style.transform = 'translateY(0)';
            });
          } else {
            project.style.opacity = '0';
            project.style.transform = 'translateY(10px)';
            setTimeout(() => {
              if (project.style.opacity === '0') {
                project.style.display = 'none';
              }
            }, 300);
          }
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProjectFilters);
</script>
