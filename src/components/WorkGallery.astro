---

<div class="pt-6 md:pt-10 pb-[var(--spacing-section-padding)]">
  <!-- Header Section -->
  <header class="max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] mb-12 md:mb-16 scroll-reveal">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 pb-8 border-b border-outline-variant">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 font-plus-jakarta-sans text-[11px] tracking-[0.15em] font-bold text-on-primary bg-primary py-1 px-3 mb-4 rounded-sm uppercase">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Bento Work Collection
        </div>
        <h1 class="font-plus-jakarta-sans font-extrabold text-primary text-[32px] sm:text-[42px] md:text-[54px] leading-[1.1] uppercase tracking-tight mb-4">
          Selected Interventions
        </h1>
        <p class="font-plus-jakarta-sans text-[15px] sm:text-[17px] md:text-[18px] text-secondary leading-relaxed">
          A strategic grid of high-impact digital products, brand identities, and full-stack technical solutions designed for global scale.
        </p>
      </div>

      <!-- Filter Buttons -->
      <nav aria-label="Project category filters" class="flex items-center gap-2 sm:gap-3 overflow-x-auto pb-2 scrollbar-none w-full lg:w-auto">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat.key}
            class={[
              "filter-btn font-plus-jakarta-sans text-[12px] tracking-[0.08em] font-bold uppercase whitespace-nowrap px-4 py-2.5 rounded-full transition-all duration-300 cursor-pointer border",
              idx === 0
                ? "active bg-primary text-on-primary border-primary shadow-sm"
                : "bg-surface-container-low text-secondary border-outline-variant hover:border-primary hover:text-primary",
            ].join(" ")}
          >
            {cat.label}
          </button>
        ))}
      </nav>
    </div>
  </header>

  <!-- Bento Grid Container -->
  <section class="max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)]">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 sm:gap-8 scroll-stagger" id="bento-grid">
      
      {bentoProjects.map((project) => (
        <article
          class={[
            "bento-item group relative rounded-xl bg-surface-container-lowest border border-outline-variant overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 flex flex-col justify-between scroll-stagger-item",
            project.colSpan,
          ].join(" ")}
          data-category={project.category}
        >
          <a href={project.href} class="block h-full flex flex-col justify-between p-6 sm:p-8">
            <!-- Top Metadata -->
            <div>
              <div class="flex items-center justify-between gap-4 mb-4">
                <span class="font-plus-jakarta-sans text-[11px] font-bold tracking-widest text-secondary uppercase bg-surface-container-high px-2.5 py-1 rounded">
                  {project.subtitle}
                </span>
                {project.date && (
                  <span class="font-plus-jakarta-sans text-[12px] font-medium text-outline">
                    {project.date}
                  </span>
                )}
              </div>

              <!-- Title -->
              <h3 class="font-plus-jakarta-sans font-bold text-[22px] sm:text-[28px] lg:text-[32px] text-primary group-hover:text-tertiary transition-colors leading-tight mb-3">
                {project.title}
              </h3>

              <!-- Description -->
              <p class="font-plus-jakarta-sans text-[14px] sm:text-[15px] text-on-surface-variant leading-relaxed mb-6 line-clamp-3">
                {project.description}
              </p>
            </div>

            <!-- Visual Image Display -->
            <div class={`relative ${project.isFeatured ? 'h-64 sm:h-80 md:h-96' : 'h-48 sm:h-56 md:h-64'} overflow-hidden rounded-lg bg-surface-container-high border border-outline-variant mb-6 group`}>
              <img
                src={project.imageUrl}
                alt={project.imageAlt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity"></div>
              
              <!-- Metric Badge overlay if present -->
              {project.metrics && (
                <div class="absolute bottom-4 left-4 bg-background/90 backdrop-blur-md px-3.5 py-2 rounded-lg border border-outline-variant/60 shadow-md">
                  <div class="text-[10px] uppercase tracking-wider text-secondary font-bold">{project.metrics.label}</div>
                  <div class="text-[16px] font-extrabold text-primary">{project.metrics.value}</div>
                </div>
              )}
            </div>

            <!-- Bottom Tags & Arrow -->
            <div class="pt-4 border-t border-outline-variant/60 flex items-center justify-between gap-4 mt-auto">
              <div class="flex flex-wrap items-center gap-1.5 sm:gap-2">
                {project.tags.map((tag) => (
                  <span class="font-plus-jakarta-sans text-[11px] font-medium bg-surface-container text-on-surface-variant px-2.5 py-1 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              
              <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center shrink-0 group-hover:bg-tertiary transition-colors shadow-sm">
                <span class="material-symbols-outlined text-[20px] group-hover:translate-x-0.5 transition-transform" aria-hidden="true">
                  arrow_forward
                </span>
              </div>
            </div>
          </a>
        </article>
      ))}

      <!-- Interactive Bento Stat Tile (Adds design richness to the grid) -->
      <article class="col-span-1 md:col-span-1 lg:col-span-4 rounded-xl bg-primary text-on-primary p-6 sm:p-8 flex flex-col justify-between border border-outline-variant shadow-md">
        <div>
          <span class="font-plus-jakarta-sans text-[11px] font-bold tracking-widest text-on-primary-container uppercase bg-primary-container px-2.5 py-1 rounded inline-block mb-4">
            IMPACT METRICS
          </span>
          <h3 class="font-plus-jakarta-sans font-bold text-[24px] sm:text-[28px] text-on-primary mb-2">
            Engineering Precision
          </h3>
          <p class="font-plus-jakarta-sans text-[14px] text-on-primary-container leading-relaxed">
            Consistently delivering sub-second response times, bulletproof test coverage, and human-centered design elegance.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4 pt-6 mt-6 border-t border-outline-variant/20">
          <div>
            <div class="text-[28px] font-black text-on-primary">100%</div>
            <div class="text-[11px] text-on-primary-container uppercase font-bold tracking-wider">Client On-Time Rate</div>
          </div>
          <div>
            <div class="text-[28px] font-black text-on-primary">14+</div>
            <div class="text-[11px] text-on-primary-container uppercase font-bold tracking-wider">Global Shipments</div>
          </div>
        </div>
      </article>

    </div>
  </section>
</div>

<script>
  function initBentoFilters() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const bentoItems = document.querySelectorAll<HTMLElement>('.bento-item');

    if (!buttons.length || !bentoItems.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-filter');

        // Update active button state
        buttons.forEach((b) => {
          b.classList.remove('active', 'bg-primary', 'text-on-primary', 'border-primary', 'shadow-sm');
          b.classList.add('bg-surface-container-low', 'text-secondary', 'border-outline-variant');
        });
        btn.classList.add('active', 'bg-primary', 'text-on-primary', 'border-primary', 'shadow-sm');
        btn.classList.remove('bg-surface-container-low', 'text-secondary', 'border-outline-variant');

        // Smooth filter transition
        bentoItems.forEach((item) => {
          const itemCategory = item.getAttribute('data-category');
          if (category === 'all' || itemCategory === category) {
            item.style.display = 'flex';
            requestAnimationFrame(() => {
              item.style.opacity = '1';
              item.style.transform = 'scale(1)';
            });
          } else {
            item.style.opacity = '0';
            item.style.transform = 'scale(0.96)';
            setTimeout(() => {
              if (item.style.opacity === '0') {
                item.style.display = 'none';
              }
            }, 250);
          }
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initBentoFilters);
</script>
