---
/**
 * AboutHero — Hero / Executive Profile section for the About page.
 * Strictly typed interface with default content fallback.
 */

export interface Props {
  badge?:        string;
  title?:        string;
  description?:  string;
  resumeUrl?:    string;
  portfolioUrl?: string;
  portraitUrl?:  string;
  portraitAlt?:  string;
}

const {
  badge        = "EXECUTIVE PROFILE",
  title        = "Crafting strategies for the digital frontier.",
  description  = "With over a decade of experience in corporate leadership and creative direction, I bridge the gap between architectural precision and human-centric design.",
  resumeUrl    = "/resume.pdf",
  portfolioUrl = "/work/",
  portraitUrl  = "https://lh3.googleusercontent.com/aida-public/AB6AXuCR5z3jho37U12VEDC29d7D_OHQ67jjVq1uhdHEnBtD80rwaWEAaWaeZqaLUpuWt8CBqp2D22ePWWl4CiTg5CZsVFrakZLZyjT8lJZUBu9oz20iTT_YB-vb2ZXiS6TzYr6oB_LV30qgiSQd-x2mUCFYdk7emMdEyDhza8pQfxUBIRCZDwaaRZRgrkWq0xH3NBB9JndmJrypvToppSsCJtLPvUP57xluxZAIzpbWe5oWK2ySQJ3kewHSF5MLo9d1kpwGlr3POrBOE5s",
  portraitAlt  = "Mohammed Shammas — Executive Portrait",
} = Astro.props;
---

<section class="py-[var(--spacing-section-padding)] px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-[var(--spacing-gutter)] items-center">

    <!-- Bio / Info Column -->
    <div class="md:col-span-7 order-2 md:order-1 scroll-reveal">
      <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-secondary mb-4 block uppercase">
        {badge}
      </span>
      <h1 class="font-plus-jakarta-sans font-bold text-[36px] md:text-[72px] leading-[1.1] text-primary mb-8 tracking-tight">
        {title}
      </h1>
      <p class="font-plus-jakarta-sans text-[18px] leading-relaxed text-on-surface-variant max-w-xl mb-10">
        {description}
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href={resumeUrl}
          download
          class="bg-primary text-on-primary px-8 py-4 rounded-sm font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold flex items-center gap-2 hover:opacity-90 transition-opacity active:scale-95 inline-flex"
        >
          <span class="material-symbols-outlined text-[20px]" aria-hidden="true">download</span>
          DOWNLOAD RESUME (PDF)
        </a>
        <a
          href={portfolioUrl}
          class="border border-primary text-primary px-8 py-4 rounded-sm font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold hover:bg-primary hover:text-white transition-all active:scale-95 inline-flex"
        >
          VIEW PORTFOLIO
        </a>
      </div>
    </div>

    <!-- Image Column -->
    <div class="md:col-span-5 order-1 md:order-2 flex justify-center md:justify-end scroll-reveal-right">
      <div class="md:col-span-6 relative flex justify-center md:justify-end scroll-reveal-right">
      <div class="relative w-full aspect-[4/5] max-w-[480px]">
        <!-- Decorative rotated border -->
        <div
          class="absolute -inset-4 border border-outline-variant rounded-lg -z-10 transform rotate-2"
          aria-hidden="true"
        ></div>

        <img
          src={portraitUrl}
          alt="Mohammed Shammas — Developer and Problem Solver"
          width="480"
          height="600"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover rounded-lg shadow-sm border border-outline-variant grayscale hover:grayscale-0 transition-all duration-700"
        />
      </div>
    </div>
    </div>

  </div>
</section>
