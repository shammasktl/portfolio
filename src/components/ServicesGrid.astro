---
/**
 * ServicesGrid — Detailed services capabilities section.
 * Uses the site's established alternating layout pattern from Projects.astro,
 * with skill tags from Skills.astro — fully consistent with the design system.
 */

interface Service {
  number:       string;
  icon:         string;
  category:     string;
  title:        string;
  description:  string;
  deliverables: string[];
  tags:         string[];
}

const services: Service[] = [
  {
    number:      "01",
    icon:        "code_blocks",
    category:    "ENGINEERING",
    title:       "Full-Stack Web Architecture",
    description: "Engineered for speed, scalability, and long-term maintainability. I build modern web applications using Astro, React, TypeScript, and robust backend solutions — with clean, modular code you can confidently build on.",
    deliverables: [
      "Custom Astro, React & Next.js development",
      "Headless CMS & GraphQL / REST API integration",
      "Type-safe modular component architecture",
      "Auth systems, forms, and data pipelines",
    ],
    tags: ["ASTRO", "REACT", "TYPESCRIPT", "NODE.JS"],
  },
  {
    number:      "02",
    icon:        "draw",
    category:    "DESIGN",
    title:       "UI / UX & Design Systems",
    description: "Bespoke design systems built with precision. From tokenized design tokens and responsive grid layouts to micro-interactions and animations that leave a lasting impression on every viewport.",
    deliverables: [
      "Tokenized design systems & component libraries",
      "Mobile-first responsive UI/UX design",
      "Micro-animations and interaction patterns",
      "Figma-to-code handoff with zero design debt",
    ],
    tags: ["DESIGN SYSTEMS", "TAILWIND", "GSAP", "FIGMA"],
  },
  {
    number:      "03",
    icon:        "lightbulb",
    category:    "ADVISORY",
    title:       "Technical Advisory & Consulting",
    description: "Guiding founders and teams through critical engineering decisions, technology stack selection, codebase refactoring, and establishing sustainable developer practices that scale with your organization.",
    deliverables: [
      "Architecture & codebase audits",
      "Tech stack evaluation & recommendations",
      "Developer tooling & DX improvements",
      "Code review, mentorship & team workflows",
    ],
    tags: ["STRATEGY", "AUDITS", "MENTORSHIP", "AGILE"],
  },
  {
    number:      "04",
    icon:        "bolt",
    category:    "OPTIMIZATION",
    title:       "Performance & SEO",
    description: "Sub-second load times and top search rankings are not afterthoughts — they are engineered into the foundation. I audit, optimize, and monitor Core Web Vitals, accessibility, and technical SEO.",
    deliverables: [
      "Core Web Vitals & Lighthouse optimization",
      "Technical SEO & structured data markup",
      "WCAG 2.1 accessibility audits & fixes",
      "Image, bundle & payload size reduction",
    ],
    tags: ["CORE WEB VITALS", "SEO", "WCAG", "ANALYTICS"],
  },
];
---

<section
  id="services-grid"
  class="py-[var(--spacing-section-padding)] bg-surface-container-lowest"
  aria-labelledby="services-grid-heading"
>
  <div class="container max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)]">

    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-20 scroll-reveal gap-4">
      <div>
        <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-secondary uppercase">
          What I Deliver
        </span>
        <h2
          id="services-grid-heading"
          class="font-plus-jakarta-sans font-semibold text-primary mt-2 text-[40px] md:text-[48px] leading-[1.2] tracking-tight"
        >
          Core Capabilities
        </h2>
      </div>
      <p class="font-plus-jakarta-sans text-[15px] text-secondary max-w-sm leading-relaxed">
        Every engagement is scoped precisely — no bloat, no ambiguity, just clean execution from kickoff to launch.
      </p>
    </div>

    <!-- Service Entries — alternating layout like Projects.astro -->
    <div class="space-y-24 md:space-y-32">
      {services.map((service, idx) => (
        <article class="grid grid-cols-1 md:grid-cols-12 gap-[var(--spacing-gutter)] items-start">

          <!-- Visual Block -->
          <div
            class={[
              "md:col-span-6 bg-surface-container border border-outline-variant rounded-sm overflow-hidden",
              idx % 2 !== 0 ? "md:order-2" : "",
            ].join(" ")}
          >
            <!-- Top Header Bar -->
            <div class={[
              idx % 2 !== 0 ? "scroll-reveal-right" : "scroll-reveal-left",
            ].join(" ")}>
              <div class="flex items-center justify-between p-5 border-b border-outline-variant">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-sm bg-primary text-on-primary flex items-center justify-center">
                    <span class="material-symbols-outlined text-[20px]">{service.icon}</span>
                  </div>
                  <span class="font-plus-jakarta-sans text-[11px] tracking-[0.15em] font-bold text-secondary uppercase">
                    {service.category}
                  </span>
                </div>
                <span class="font-plus-jakarta-sans text-[32px] font-black text-outline-variant/40 tabular-nums leading-none select-none">
                  {service.number}
                </span>
              </div>

              <!-- Deliverables List inside the visual block -->
              <div class="p-6 space-y-3">
                {service.deliverables.map((item) => (
                  <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-primary text-[16px] mt-0.5 shrink-0" aria-hidden="true">
                      check
                    </span>
                    <span class="font-plus-jakarta-sans text-[14px] text-on-surface leading-snug">{item}</span>
                  </div>
                ))}
              </div>

              <!-- Tags -->
              <div class="px-6 pb-6 flex flex-wrap gap-2">
                {service.tags.map((tag) => (
                  <span class="bg-surface-container-high px-3 py-1 rounded-full font-plus-jakarta-sans text-[10px] tracking-[0.1em] font-bold text-on-surface-variant">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Text Block -->
          <div
            class={[
              "md:col-span-6 scroll-reveal",
              idx % 2 !== 0 ? "md:order-1 md:pr-8" : "md:pl-8",
            ].join(" ")}
          >
            <h3 class="font-plus-jakarta-sans font-semibold text-primary text-[28px] md:text-[36px] leading-tight mb-5">
              {service.title}
            </h3>

            <p class="font-plus-jakarta-sans text-[16px] leading-relaxed text-secondary mb-8">
              {service.description}
            </p>

            <a
              href="/contact/"
              class="bg-primary text-on-primary px-6 py-3 rounded-sm font-plus-jakarta-sans font-bold text-[12px] tracking-[0.08em] hover:bg-primary-container transition-colors active:scale-95 inline-flex items-center gap-2 group"
            >
              DISCUSS THIS SERVICE
              <span class="material-symbols-outlined text-[16px] transition-transform group-hover:translate-x-1" aria-hidden="true">
                arrow_forward
              </span>
            </a>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>
