---
/**
 * NextSectionCTA — Pre-footer banner promoting navigation to the next section.
 */

interface Props {
  tagline?: string;
  heading?: string;
  href?: string;
}

const {
  tagline = "CONTINUE THE JOURNEY",
  heading = "Next: About Me",
  href = "/about/",
} = Astro.props;
---

<section class="border-t border-outline-variant py-24 bg-surface-container-low">
  <div class="max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] flex flex-col items-center text-center scroll-reveal">
    <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-secondary mb-4 block uppercase">
      {tagline}
    </span>
    <a href={href} class="group flex items-center gap-4 md:gap-6">
      <h2 class="font-plus-jakarta-sans font-bold text-[36px] md:text-[72px] text-primary group-hover:text-tertiary transition-colors leading-tight">
        {heading}
      </h2>
      <span class="material-symbols-outlined text-[40px] md:text-[72px] text-primary transition-transform group-hover:translate-x-4" aria-hidden="true">
        arrow_right_alt
      </span>
    </a>
  </div>
</section>
