---

<section
  id="projects"
  class="py-16 md:py-24 lg:py-32 bg-surface"
  aria-labelledby="projects-heading"
>
  <div class="max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)]">

    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 sm:mb-16 md:mb-20 scroll-reveal">
      <div>
        <span class="font-plus-jakarta-sans text-[11px] sm:text-[12px] tracking-[0.15em] font-bold text-secondary uppercase bg-surface-container px-3 py-1 rounded">
          Selected Interventions
        </span>
        <h2
          id="projects-heading"
          class="font-plus-jakarta-sans font-extrabold text-primary mt-3 text-[32px] sm:text-[42px] md:text-[48px] leading-[1.15] tracking-tight uppercase"
        >
          Featured Case Studies
        </h2>
      </div>
      <a
        href="/work/"
        class="hidden md:inline-flex items-center gap-2 text-primary font-bold text-[14px] uppercase tracking-wider group transition-all duration-200 hover:gap-3"
        aria-label="View all projects"
      >
        View All Projects
        <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Project List -->
    <div class="space-y-16 sm:space-y-20 md:space-y-28">
      {projects.map((project) => (
        <article class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">

          <!-- Image Container -->
          <div
            class={[
              "lg:col-span-7 bg-surface-container-low overflow-hidden rounded-xl border border-outline-variant/70 shadow-sm",
              !project.imageLeft ? "lg:order-2" : "",
            ].join(" ")}
          >
            <div
              class={[
                "w-full aspect-[16/10] sm:aspect-video bg-cover bg-center transition-transform duration-700 hover:scale-105",
                project.imageLeft ? "scroll-reveal-left" : "scroll-reveal-right",
              ].join(" ")}
              style={`background-image: url('${project.imageUrl}');`}
              role="img"
              aria-label={project.imageAlt}
            ></div>
          </div>

          <!-- Text Container -->
          <div
            class={[
              "lg:col-span-5 scroll-reveal",
              project.imageLeft ? "lg:pl-6" : "lg:order-1 lg:pr-6",
            ].join(" ")}
          >
            <span
              class={[
                "font-plus-jakarta-sans text-[11px] tracking-[0.12em] font-bold px-3 py-1 inline-block mb-4 rounded-sm uppercase",
                project.categoryBg,
                project.categoryText,
              ].join(" ")}
            >
              {project.category}
            </span>

            <h3 class="font-plus-jakarta-sans font-bold text-primary text-[24px] sm:text-[30px] md:text-[36px] leading-tight mb-4">
              {project.title}
            </h3>

            <p class="font-plus-jakarta-sans text-[15px] sm:text-[16px] leading-relaxed text-on-surface-variant mb-8">
              {project.description}
            </p>

            <a
              href={project.href || "/work/"}
              class="bg-primary text-on-primary px-6 py-3.5 rounded-lg font-bold text-[14px] transition-all duration-200 hover:bg-primary-container hover:shadow-lg active:scale-95 inline-flex items-center gap-2 group"
            >
              Explore Project
              <span class="material-symbols-outlined text-[18px] transition-transform group-hover:translate-x-1" aria-hidden="true">
                arrow_forward
              </span>
            </a>
          </div>

        </article>
      ))}
    </div>

    <!-- Mobile View All Button -->
    <div class="text-center mt-12 md:hidden">
      <a href="/work/" class="bg-surface-container text-primary font-bold px-6 py-3 rounded-lg inline-flex items-center gap-2 border border-outline-variant">
        View All Projects
        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">arrow_right_alt</span>
      </a>
    </div>

  </div>
</section>
