---
/**
 * Projects — Selected work / case studies section.
 * Alternating image-left / image-right layout.
 * Uses scroll-reveal-left / scroll-reveal-right for GSAP directional reveals.
 */

interface Project {
  category:    string;
  categoryBg:  string;
  categoryText: string;
  title:       string;
  description: string;
  imageUrl:    string;
  imageAlt:    string;
  imageLeft:   boolean; // true = image on left, false = image on right
}

