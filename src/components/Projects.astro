  },
  {
    category:     "Lifestyle",
    categoryBg:   "bg-secondary-fixed",
    categoryText: "text-on-secondary-fixed-variant",
    title:        "Luxury Retail Ecosystem",
    description:  "Developing an omni-channel e-commerce experience for a heritage luxury brand. Seamlessly integrating digital and physical boutique interactions.",
