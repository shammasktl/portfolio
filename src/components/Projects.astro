    imageAlt:     "Editorial luxury fashion website — bold typography with charcoal and ivory palette",
    imageLeft:    false,
  },
  {
    category:     "Enterprise",
    categoryBg:   "bg-primary-fixed",
    categoryText: "text-on-primary-fixed-variant",
    title:        "Next-Gen SaaS Analytics",
    description:  "Modernizing the data visualization layer for a leading enterprise analytics platform. Simplifying complex data sets into actionable executive insights.",
    imageUrl:     "https://lh3.googleusercontent.com/aida-public/AB6AXuDdOneOMgBaJxd91LW6PbFv2oswMugTcPs4T3DX0r-JQsFTOtr2edIJhFkj_cke_JN_IM-vAO6E7Ykkj1k7RdXfid1nLvxjUvNeMiGXvmSIHSvA4x0F5kR0T6dJFfuMq27fBG5F4w5C0d341T_TCvS6iy00rnGZUCe47aqo6c0BpBXYt98hvjG5yV6erhwH9gpYsNAzUGwZpLMHT-GF9AZFsyzQakVBmK2xDZsG_k1fJAPqnA_oDbYd7ana_No9uFgqZiMRS6l2OZc",
    imageAlt:     "Corporate SaaS intranet dashboard with data visualisation charts in a glass-walled office",
    imageLeft:    true,
  },
