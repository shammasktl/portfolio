---

<section
  id="services"
  class="py-[var(--spacing-section-padding)] bg-surface"
  aria-labelledby="projects-heading"
>
  <div class="container max-w-[var(--spacing-container-max)] mx-auto px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)]">

    <!-- Section Header -->
    <div class="flex justify-between items-end mb-16 scroll-reveal">
      <div>
        <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-secondary uppercase">
          Selected Work
        </span>
        <h2
          id="projects-heading"
          class="font-plus-jakarta-sans font-semibold text-primary mt-2 text-[48px] leading-[1.2] tracking-tight"
        >
          Case Studies
        </h2>
      </div>
      <a
        href="/work/"
        class="hidden md:flex items-center gap-2 text-primary font-bold group transition-all duration-200 hover:gap-3"
        aria-label="View all projects"
      >
        View All Projects
        <span class="inline-block transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Project List -->
    <div class="space-y-24">
      {projects.map((project) => (
        <article class={`grid grid-cols-1 md:grid-cols-12 gap-[var(--spacing-gutter)] items-center`}>

          <!-- Image -->
          <div
            class={[
              "md:col-span-7 bg-surface-container-low overflow-hidden rounded-sm",
              !project.imageLeft ? "md:order-2" : "",
            ].join(" ")}
          >
            <div
              class={[
                "w-full aspect-video bg-cover bg-center transition-transform duration-700 hover:scale-105",
                project.imageLeft ? "scroll-reveal-left" : "scroll-reveal-right",
              ].join(" ")}
              style={`background-image: url('${project.imageUrl}');`}
              role="img"
              aria-label={project.imageAlt}
            ></div>
          </div>

          <!-- Text -->
          <div
            class={[
              "md:col-span-5 scroll-reveal",
              project.imageLeft ? "md:pl-12" : "md:order-1 md:pr-12",
            ].join(" ")}
          >
            <span
              class={[
                "font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold px-3 py-1 inline-block mb-4 rounded-sm",
                project.categoryBg,
                project.categoryText,
              ].join(" ")}
            >
              {project.category.toUpperCase()}
            </span>

            <h3 class="font-plus-jakarta-sans font-semibold text-primary text-[32px] leading-tight mb-4">
              {project.title}
            </h3>

            <p class="font-plus-jakarta-sans text-[16px] leading-relaxed text-on-surface-variant mb-8">
              {project.description}
            </p>

            <a
              href="/work/"
              class="bg-primary text-on-primary px-6 py-3 rounded-sm font-bold transition-all hover:bg-primary-container active:scale-95 inline-flex items-center gap-2 group"
            >
              Read Case Study
              <span class="material-symbols-outlined text-[18px] transition-transform group-hover:translate-x-1" aria-hidden="true">
                arrow_forward
              </span>
            </a>
          </div>

        </article>
      ))}
    </div>

    <!-- Mobile: View All link -->
    <div class="text-center mt-20 md:hidden">
      <a href="/work/" class="text-primary font-bold inline-flex items-center gap-2">
        View All Projects
        <span class="material-symbols-outlined" aria-hidden="true">arrow_right_alt</span>
      </a>
    </div>

  </div>
</section>
