---
/**
 * Projects — Selected Case Studies Section Template.
 * 
 * =========================================================================
 * TEMPLATE GUIDANCE FOR ADDING NEW CASE STUDIES:
 * 
 * To add or edit case studies:
 * 1. Modify the `projects` array below.
 * 2. Each object represents one case study.
 * 3. Set `imageLeft: true` for odd items and `imageLeft: false` for even items
 *    to preserve the alternating visual flow on desktop.
 * =========================================================================
 */

export interface ProjectTemplateItem {
  id:           string;
  category:     string;
  categoryBg:   string;
  categoryText: string;
  title:        string;
  description:  string;
  imageUrl:     string;
  imageAlt:     string;
  imageLeft:    boolean; // true = image on left, false = image on right
  href?:        string;
}

