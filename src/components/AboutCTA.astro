---
/**
 * AboutCTA — Dark persistent call-to-action banner for the About page.
 */

export interface Props {
  heading?: string;
  linkLabel?: string;
  linkHref?: string;
}

const {
  heading   = "Ready to initiate?",
  linkLabel = "Get in Touch",
  linkHref  = "/contact/",
} = Astro.props;
---

<section class="bg-primary text-on-primary py-24 text-center">
  <div class="px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto scroll-reveal">
    <h2 class="font-plus-jakarta-sans font-bold text-[36px] md:text-[72px] leading-[1.1] mb-8">
      {heading}
    </h2>
    <a
      href={linkHref}
      class="inline-block border-b-2 border-on-primary font-plus-jakarta-sans font-semibold text-[24px] md:text-[32px] hover:pb-2 transition-all duration-300"
    >
      {linkLabel}
    </a>
  </div>
</section>
