---
/**
 * ContactHero — Direct contact links and portrait for the Contact page.
 * Includes strictly typed props with fallback data for Mohammed Shammas.
 */

export interface ContactLink {
  icon:  string;
  label: string;
  href:  string;
}

export interface Props {
  badge?:        string;
  title?:        string;
  description?:  string;
  contactLinks?: ContactLink[];
  portraitUrl?:  string;
  portraitAlt?:  string;
}

const defaultContactLinks: ContactLink[] = [
  {
    icon:  "mail",
    label: "hello@mohammedshammas.com",
    href:  "mailto:hello@mohammedshammas.com",
  },
  {
    icon:  "work",
    label: "linkedin.com/in/mohammedshammas",
    href:  "https://linkedin.com/in/mohammedshammas",
  },
  {
    icon:  "code",
    label: "github.com/shammasktl",
    href:  "https://github.com/shammasktl",
  },
];

const {
  badge        = "CONNECT WITH ME",
  title        = "Let's Connect.",
  description  = "I am currently available for executive consulting, high-level project partnerships, and global technical leadership engagements. Reach out to discuss how we can create structural excellence together.",
  contactLinks = defaultContactLinks,
  portraitUrl  = "https://lh3.googleusercontent.com/aida-public/AB6AXuDGDW2Tn2xV81UKm6IYd-UF6KGpmFzMBAu6hZlptgS228BSkb4Uj4_lhkoqRuDdbBJ3bydQnAex9iRCAagEAESYmiGU1LGoG5ZnIYsQybHxfad-RU4mkGNjzz8FvZHDCIDqnidSqewfHR74wugjksPfge-D2weS1IUJg35_mlWURMphgLcXOhRJFZUCGul0KtVC2NpRO9pl5m283HQqf3Gpe9zxbrnnGKfoyJfEGjZzdJhswArVxT_h8Z-wheECtej31dUO81dERFU",
  portraitAlt  = "Mohammed Shammas — Executive Portrait",
} = Astro.props;
---

<section class="px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto py-[var(--spacing-section-padding)]">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-[var(--spacing-gutter)] items-center">

    <!-- Left Content Column -->
    <div class="lg:col-span-7 scroll-reveal">
      <span class="font-plus-jakarta-sans text-[12px] tracking-[0.1em] font-bold text-tertiary-container uppercase mb-6 block">
        {badge}
      </span>
      <h1 class="font-plus-jakarta-sans font-bold text-[36px] md:text-[72px] leading-[1.1] text-primary mb-8 tracking-tight">
        {title}
      </h1>
      <p class="font-plus-jakarta-sans text-[18px] leading-relaxed text-on-surface-variant max-w-xl mb-12">
        {description}
      </p>

      <!-- Direct Contact Links -->
      <div class="flex flex-col gap-6">
        {contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="group flex items-center gap-4 transition-all"
          >
            <div class="w-12 h-12 flex items-center justify-center bg-surface-container-high rounded-full group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              <span class="material-symbols-outlined text-[20px]" aria-hidden="true">
                {link.icon}
              </span>
            </div>
            <span class="font-plus-jakarta-sans text-[18px] text-primary border-b border-transparent group-hover:border-primary transition-all">
              {link.label}
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Right Image Column -->
    <div class="lg:col-span-5 scroll-reveal-right">
      <div class="relative w-full aspect-[4/5] bg-surface-container-high overflow-hidden rounded-sm border border-outline-variant shadow-sm">
        <img
          src={portraitUrl}
          alt={portraitAlt}
          width="480"
          height="600"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out scale-105 hover:scale-100"
        />
      </div>
    </div>

  </div>
</section>
