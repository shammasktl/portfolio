---
import "../styles/global.css";
import TopAppBar from "../components/TopAppBar.astro";
import NavDrawer from "../components/NavDrawer.astro";

interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
  canonical?:   string;
  robots?:      string;
  pageType?:    "website" | "profile";
}

const {
  title       = "Mohammed Shammas | The Developer Cum Solver",
  description = "Crafting digital experiences with precision and purpose. Mohammed Shammas bridges the gap between high-level strategy and pixel-perfect execution for global brands.",
  ogImage     = "/og-image.svg",
  canonical   = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href,
  robots      = "index, follow",
  pageType    = "website",
} = Astro.props;

const siteName = "Mohammed Shammas";
const absoluteOgImage = new URL(ogImage, Astro.site ?? Astro.url).href;
const siteUrl = new URL("/", Astro.site ?? Astro.url).href;
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteName,
  url: siteUrl,
  image: absoluteOgImage,
  jobTitle: "Full-Stack Developer and Digital Problem Solver",
  sameAs: ["https://github.com/shammasktl", "https://linkedin.com/in/mohammedshammas"],
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mohammed Shammas" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type"        content={pageType} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={absoluteOgImage} />
    <meta property="og:image:alt"   content={`${siteName} — Developer and Problem Solver`} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:locale"      content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:url"         content={canonical} />
    <meta name="twitter:image"       content={absoluteOgImage} />
    <meta name="twitter:image:alt"   content={`${siteName} — Developer and Problem Solver`} />

    <!-- Theme / Favicon -->
    <meta name="theme-color" content="#f8f9fa" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>

  <body class="bg-background text-on-background font-plus-jakarta-sans overflow-x-hidden">

    <!-- Reading Progress Bar -->
    <div
      class="reading-progress-bar fixed top-0 left-0 h-0.5 bg-primary z-[100] transition-all duration-75"
      style="width: 0%;"
      aria-hidden="true"
    ></div>

    <!-- Navigation -->
    <TopAppBar />
    <NavDrawer />

    <!-- Page Content -->
    <main class="mt-16 sm:mt-20">
      <slot />
    </main>


    <!-- Back to Top Circular Progress Button -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-8 right-8 z-45 w-12 h-12 rounded-full bg-primary border border-outline-variant flex items-center justify-center text-on-primary shadow-lg cursor-pointer opacity-0 translate-y-4 pointer-events-none transition-all duration-300 hover:scale-105"
    >
      <svg class="w-full h-full absolute inset-0 -rotate-90 p-0.5" viewBox="0 0 100 100" aria-hidden="true">
        <circle cx="50" cy="50" r="44" stroke="rgba(255,255,255,0.08)" stroke-width="5" fill="transparent"></circle>
        <circle
          class="back-to-top-progress-path"
          cx="50" cy="50" r="44"
          stroke="rgba(255,255,255,0.6)"
          stroke-width="5"
          fill="transparent"
          stroke-linecap="round"
        ></circle>
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 relative z-10" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
      </svg>
    </button>

    <!-- Scroll orchestration (Lenis + GSAP) -->
    <script>
      import { initScroll } from "../scripts/scroll";
      document.addEventListener("DOMContentLoaded", () => {
        initScroll();
      });
    </script>
  </body>
</html>
